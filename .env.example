# Agent Bus Server Configuration
# Copy this to .env and fill in your values

# Per-agent authentication tokens — recommended for real use.
# Format: agent=token,agent=token
AGENT_BUS_AGENT_TOKENS=architect=change-me-architect-token,coder=change-me-coder-token

# Legacy shared token — supported for local development or migration only.
# If AGENT_BUS_AGENT_TOKENS is set, per-agent tokens are used instead.
# AGENT_BUS_TOKEN=change-me-to-a-random-secret

# Server bind address and port
AGENT_BUS_HOST=0.0.0.0
AGENT_BUS_PORT=8800

# Bootstrap secret — machines present this low-privilege secret via
# POST /bootstrap/token to receive their high-privilege role token.
# Leave unset/empty to disable the bootstrap endpoint (recommended for
# production machines that do their own token provisioning).
# AGENT_BUS_BOOTSTRAP_SECRET=change-me-to-a-random-secret

# SQLite database file path
AGENT_BUS_DB_PATH=data/agent-bus.db
