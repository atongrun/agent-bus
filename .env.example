# Agent Bus Server Configuration
# Copy this to .env, protect it with chmod 600, and fill in your values.

# Required for Docker and recommended for every real deployment.
# Format: agent=token,agent=token
# Add a unique token for every allowed agent before starting.
AGENT_BUS_AGENT_TOKENS=

# Legacy shared token — supported for local development or migration only.
# If AGENT_BUS_AGENT_TOKENS is set, per-agent tokens are used instead.
# AGENT_BUS_TOKEN=

# Server bind address and port. Docker Compose supplies its own container-side
# values; these remain useful when starting the server directly.
AGENT_BUS_HOST=0.0.0.0
AGENT_BUS_PORT=8800

# Bootstrap token provisioning remains disabled when this is empty.
# AGENT_BUS_BOOTSTRAP_SECRET=

# SQLite path used when starting the server directly. Docker Compose overrides
# this with the persistent /data/agent-bus.db path.
AGENT_BUS_DB_PATH=data/agent-bus.db

# Optional host-side Compose settings.
# AGENT_BUS_BIND_ADDRESS=127.0.0.1
# AGENT_BUS_PUBLISHED_PORT=8800
# AGENT_BUS_DATA_VOLUME=agent-bus-data
