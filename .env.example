# Agent Bus Server Configuration
# Copy this to .env and fill in your values

# Authentication token — clients must send this in Authorization header
AGENT_BUS_TOKEN=change-me-to-a-random-secret

# Server bind address and port
AGENT_BUS_HOST=0.0.0.0
AGENT_BUS_PORT=8800

# SQLite database file path
AGENT_BUS_DB_PATH=data/agent-bus.db
